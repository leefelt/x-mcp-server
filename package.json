{
	"name": "x-mcp-server",
	"version": "0.1.0",
	"description": "MCP server for X (Twitter) — post, search, engage from Claude Code",
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"x-mcp-server": "dist/index.js"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsx src/index.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"mcp",
		"twitter",
		"x",
		"claude"
	],
	"license": "MIT",
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.1",
		"twitter-api-v2": "^1.19.0",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@types/node": "^20.17.0",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	}
}
